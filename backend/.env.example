# Supabase project Postgres connection string (Settings -> Database in the
# Supabase dashboard -> Connection string -> "URI", rewritten for asyncpg).
# Format: postgresql+asyncpg://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres

# Settings -> API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_KEY=your-service-role-key

CORS_ORIGINS=["http://localhost:5173"]

# The deployed frontend's base URL -- used to build the redirect link in
# staff invite emails (Supabase sends the user here to set their password).
FRONTEND_URL=http://localhost:5173
