# Supabase project Postgres connection string (Settings -> Database in the
# Supabase dashboard -> Connection string -> "URI", rewritten for asyncpg).
# Format: postgresql+asyncpg://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres

# Settings -> API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_KEY=your-service-role-key

# Signs the one-time accept-invite links sent over WhatsApp -- generate a
# long random value (e.g. `openssl rand -hex 32`), distinct from
# SUPABASE_JWT_SECRET. Change it and every unaccepted invite link breaks.
INVITE_TOKEN_SECRET=change-me-to-a-long-random-value

CORS_ORIGINS=["http://localhost:5173"]

# The deployed frontend's base URL -- used to build the accept-invite link
# sent in staff invite WhatsApp messages.
FRONTEND_URL=http://localhost:5173

# Meta WhatsApp Cloud API -- Meta Business Manager -> WhatsApp -> API Setup
# Arbitrary string you choose; must match the "Verify token" entered in the
# Meta App dashboard's webhook configuration.
WHATSAPP_VERIFY_TOKEN=change-me-to-a-random-value
# System User access token (long-lived, for production -- not the 24h test token)
WHATSAPP_ACCESS_TOKEN=your-meta-system-user-access-token
# Phone Number ID shown in WhatsApp Business Platform settings (not the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# The Meta App's secret -- used to verify the X-Hub-Signature-256 header on inbound webhooks
WHATSAPP_APP_SECRET=your-meta-app-secret
# The actual dialable WhatsApp number, digits only (e.g. 919876543210) --
# guests scan a wa.me link built with this number
WHATSAPP_DISPLAY_PHONE_NUMBER=919876543210
